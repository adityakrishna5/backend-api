      "name": "🔐 Token Management",
      "item": [
        {
          "name": "Generate Token (Customer - Password Grant) [DEFAULT]",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', jsonData.access_token);",
                  "  const expiryTime = Math.floor(Date.now() / 1000) + jsonData.expires_in - 10;",
                  "  pm.collectionVariables.set('token_expiry', expiryTime);",
                  "  pm.test('✓ Token generated successfully', () => {",
                  "    pm.expect(jsonData.access_token).to.be.a('string');",
                  "    pm.expect(jsonData.token_type).to.equal('Bearer');",
                  "  });",
                  "  console.log('✓ customer1 token ready, expires in', jsonData.expires_in, 'sec');",
                  "} else {",
                  "  pm.test('✗ Token generation failed', () => {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "  });",
                  "  console.error('Token error:', pm.response.code, pm.response.text());",
