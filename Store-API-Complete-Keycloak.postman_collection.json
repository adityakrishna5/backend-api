{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Store APIs - Complete (Keycloak Integrated)",
    "description": "All APIs with automated Keycloak OAuth token generation. Each service on different port (8081/8082/8083)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
