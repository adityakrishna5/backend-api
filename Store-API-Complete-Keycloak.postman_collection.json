  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate Keycloak token if expired or missing",
          "const keycloakUrl = pm.variables.get('keycloak_token_url');",
          "const clientId = pm.variables.get('oauth_client_id');",
          "const clientSecret = pm.variables.get('oauth_client_secret');",
          "const tokenExpiry = parseInt(pm.variables.get('token_expiry') || '0');",
          "const now = Math.floor(Date.now() / 1000);",
          "",
          "// If token expired or doesn't exist, request new one",
          "if (!pm.variables.get('access_token') || now > tokenExpiry) {",
          "  const authRequest = {",
          "    url: keycloakUrl,",
          "    method: 'POST',",
          "    header: {",
          "      'Content-Type': 'application/x-www-form-urlencoded'",
          "    },",
          "    body: {",
          "      mode: 'urlencoded',",
          "      urlencoded: [",
          "        { key: 'client_id', value: clientId },",
          "        { key: 'client_secret', value: clientSecret },",
          "        { key: 'grant_type', value: 'password' },",
          "        { key: 'username', value: pm.variables.get('oauth_username') || 'customer1' },",
          "        { key: 'password', value: pm.variables.get('oauth_password') || 'password' }",
          "      ]",
          "    }",
          "  };",
          "",
          "  pm.sendRequest(authRequest, function(err, response) {",
          "    if (err) {",
          "      console.error('Token generation failed:', err);",
          "      pm.collectionVariables.set('access_token', 'ERROR_TOKEN_FAILED');",
          "    } else if (response.code === 200) {",
          "      const jsonData = response.json();",
          "      pm.collectionVariables.set('access_token', jsonData.access_token);",
          "      pm.collectionVariables.set('token_expiry', now + jsonData.expires_in - 10);",
          "      console.log('✓ New token generated, expires in', jsonData.expires_in, 'seconds');",
          "    } else {",
          "      console.error('Token error:', response.code, response.text());",
          "      pm.collectionVariables.set('access_token', 'ERROR_' + response.code);",
          "    }",
          "  });",
          "} else {",
          "  console.log('✓ Using cached token (expires in', tokenExpiry - now, 'seconds)');",
          "}"
        ]
      }
    }
  ],
  "item": [
